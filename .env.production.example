# =========================
# Meetra Production Example
# =========================

# ----------
# Vercel / client
# ----------
# Set this in the Vercel project environment variables
VITE_API_URL=https://your-render-backend.onrender.com
VITE_PUBLIC_JOIN_BASE_URL=https://your-vercel-frontend.vercel.app

# ----------
# Render / server
# ----------
# Set these in the Render web service environment variables
NODE_ENV=production
CLIENT_URL=https://your-vercel-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-preview-1.vercel.app,https://your-preview-2.vercel.app
MEETING_STORE_BACKEND=postgres

# Transcript persistence
TRANSCRIPT_STORE_BACKEND=postgres
TRANSCRIPT_RETENTION_DAYS=30

# Summary / captions defaults
SUMMARY_PROVIDER=heuristic
TRANSCRIPTION_PROVIDER=browser

# OpenAI summary / STT
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_TRANSCRIPTION_URL=https://api.openai.com/v1/audio/transcriptions

# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Optional host waiting-room alerts
# Your webhook should accept a JSON payload describing the waiting guest.
HOST_ALERT_EMAIL_WEBHOOK_URL=https://your-email-webhook.example.com/meetra
HOST_ALERT_SMS_WEBHOOK_URL=https://your-sms-webhook.example.com/meetra
HOST_ALERT_WEBHOOK_SECRET=change-me
