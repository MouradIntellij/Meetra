# Render / backend
NODE_ENV=production
CLIENT_URL=https://your-vercel-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-preview-1.vercel.app,https://your-preview-2.vercel.app
MEETING_STORE_BACKEND=postgres

# Transcript persistence
TRANSCRIPT_STORE_BACKEND=postgres
TRANSCRIPT_RETENTION_DAYS=30

# Summary / captions defaults
SUMMARY_PROVIDER=heuristic
TRANSCRIPTION_PROVIDER=browser

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_TRANSCRIPTION_URL=https://api.openai.com/v1/audio/transcriptions

# Database
DATABASE_URL=postgres://user:password@host:5432/database
