# TURN/STUN Server Credentials for WebRTC
TURN_SERVER=127.0.0.1
TURN_PORT=3478
TURN_USERNAME=videoconf
TURN_PASSWORD=videoconf123!
TURN_REALM=videoconf.local

# Enable TURN in your WebRTC configuration
# Use these ICE servers in your PeerConnection:
# {
#   urls: ['turn:127.0.0.1:3478'],
#   username: 'videoconf',
#   credential: 'videoconf123!',
#   credentialType: 'password'
# }

# For production, replace 127.0.0.1 with your server's public IP
