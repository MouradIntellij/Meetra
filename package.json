{
  "name": "videoconference-step7",
  "version": "2.0.0",
  "description": "VideoConf Step 7 — Production SaaS architecture",
  "private": true,
  "main": "electron/main/main.cjs",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev":        "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:client:lan":"npm run dev --workspace=client -- --host 0.0.0.0",
    "dev:desktop":"node scripts/run-desktop-env.cjs",
    "dev:desktop:prod":"node scripts/run-desktop-env.cjs --remote",
    "dev:desktop:raw":"concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run electron:open\"",
    "dev:desktop:remote":"electron .",
    "dev:desktop:lan":"concurrently \"npm run dev:server\" \"npm run dev:client:lan\" \"npm run electron:open\"",
    "electron:open":"wait-on tcp:4000 tcp:5173 && electron .",
    "build":      "npm run build --workspace=client",
    "build:desktop":"npm run build --workspace=client && electron-builder",
    "start":      "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.videoconferencepro.desktop",
    "productName": "VideoConferencePro",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "client/dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
