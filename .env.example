# ── CLIENT WEB (Vercel) ──────────────────────────────────────
# Variables publiques du frontend web.
# La visio fonctionne sans OpenAI.

VITE_API_URL=https://your-render-backend.onrender.com
VITE_PUBLIC_JOIN_BASE_URL=https://your-vercel-frontend.vercel.app
VITE_TURN_URL=turn:your-turn-domain-or-ip:3478
VITE_TURN_USERNAME=videoconf
VITE_TURN_CREDENTIAL=replace-with-your-turn-password


# ── SERVER API (Render) ──────────────────────────────────────
# Variables serveur.
# Garder OpenAI désactivé tant que vous ne voulez pas la transcription cloud.

NODE_ENV=production
CLIENT_URL=https://your-vercel-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-vercel-frontend.vercel.app,https://your-preview.vercel.app
SESSION_SECRET=replace-with-a-long-random-secret
MEETING_STORE_BACKEND=postgres
TRANSCRIPT_STORE_BACKEND=postgres
TRANSCRIPTION_PROVIDER=browser
SUMMARY_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
HOST_ALERT_EMAIL_WEBHOOK_URL=
HOST_ALERT_SMS_WEBHOOK_URL=
HOST_ALERT_WEBHOOK_SECRET=
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=
NOTIFICATION_FROM_NAME=Meetra
NOTIFICATION_FROM_EMAIL=


# ── ELECTRON DESKTOP (optionnel) ─────────────────────────────
# Variables utiles seulement si vous gardez le mode hybride Electron + Web.

APP_API_URL=https://your-render-backend.onrender.com
APP_CLIENT_URL=https://your-vercel-frontend.vercel.app
APP_PUBLIC_JOIN_BASE_URL=https://your-vercel-frontend.vercel.app
APP_TURN_URL=turn:your-turn-domain-or-ip:3478
APP_TURN_USERNAME=videoconf
APP_TURN_CREDENTIAL=replace-with-your-turn-password
